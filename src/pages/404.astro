---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found | Cyril James">
  <div class="notfound">
    <section class="notfound__head">
      <h1 class="notfound__code">404</h1>
      <h1 class="notfound__title">Page Not Found</h1>
      <p class="notfound__text">
        The page you're looking for doesn't exist or has been moved.
      </p>
    </section>
    <a href="/" class="notfound__link">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        class="icon-4"
        style="transform: translateY(2px)"
        aria-hidden="true"
      >
        <path
          fill="currentColor"
          d="M20 11v2H8v2H6v-2H4v-2h2V9h2v2zM10 7H8v2h2zm0 0h2V5h-2zm0 10H8v-2h2zm0 0h2v2h-2z"
        ></path>
      </svg>
      <span>Return to Home</span>
    </a>
  </div>
</Layout>
