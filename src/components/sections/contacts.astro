---
import ContactForm from "@/components/contact-form";
import SectionTitle from "@/components/section-title.astro";
---

<section class="flex flex-col spacing-md">
  <SectionTitle text="Contacts" />
  <section
    class="grid grid-cols-1 border border-dashed border-border lg:grid-cols-2"
  >
    <article
      class="flex flex-col spacing-lg border-b border-dashed border-border padding-lg lg:border-r lg:border-b-0"
      aria-labelledby="contact-heading"
    >
      <h1 class="text-xl font-semibold text-primary">
        Let's Connect !
      </h1>
      <p id="contact-heading" class="text-sm text-primary/75">
        For professional inquiries, project collaborations, or career
        opportunities, feel free to reach out or connect with me on any of the
        following:
      </p>
      <address class="flex flex-col spacing-sm not-italic">
        <p class="flex spacing-md">
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-5"><path fill="currentColor" d="M22 4H2v16h20zM4 18V6h16v12zM8 8H6v2h2v2h2v2h4v-2h2v-2h2V8h-2v2h-2v2h-4v-2H8z"></path></svg>
          <a
            href="mailto:deguzmancyriljames.dev@gmail.com"
            class="text-sm font-semibold hover:underline hover:underline-offset-4"
          >
            deguzmancyriljames.dev@gmail.com
          </a>
        </p>
        <p class="flex spacing-md">
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-5"><path fill="currentColor" d="M6 3h12v18H6zm10 16V5h-2v2h-4V5H8v14zm-5-4h2v2h-2z"></path></svg>
          <a
            href="tel:+639696028487"
            class="text-sm font-semibold hover:underline hover:underline-offset-4"
          >
            +63 969 602 8487
          </a>
        </p>
        <a
          href="https://github.com/quinchy"
          target="_blank"
          rel="noopener noreferrer"
          class="flex spacing-md"
          aria-label="Cyril James on GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-5"><path fill="currentColor" d="M5 2h4v2H7v2H5zm0 10H3V6h2zm2 2H5v-2h2zm2 2v-2H7v2H3v-2H1v2h2v2h4v4h2v-4h2v-2zm0 0v2H7v-2zm6-12v2H9V4zm4 2h-2V4h-2V2h4zm0 6V6h2v6zm-2 2v-2h2v2zm-2 2v-2h2v2zm0 2h-2v-2h2zm0 0h2v4h-2z" stroke="currentColor"></path></svg>
          <span class="text-sm font-semibold hover:underline hover:underline-offset-4">
            quinchy
          </span>
        </a>
        <a
          href="https://www.linkedin.com/in/quinchy/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex spacing-md"
          aria-label="Cyril James on LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="32" height="32" viewBox="0 0 32 32" class="size-5"><path fill="currentColor" d="M30.47 3.05H32v25.9h-1.53Zm-1.52 25.9h1.52v1.53h-1.52Zm0-27.43h1.52v1.53h-1.52Zm-1.53 3.05h1.53v22.86h-1.53ZM3.04 30.48h25.91V32H3.04Zm1.53-3.05h22.85v1.52H4.57Zm18.28-12.19h-1.52v-1.53h-3.05v1.53h-1.52v-1.53h-3.05v9.15h3.05v-4.57h1.52v-1.53h1.53v1.53h1.52v4.57h3.05v-6.1h-1.53zM7.61 13.71h3.05v9.15H7.61Zm0-4.57h3.05v3.05H7.61ZM4.57 3.05h22.85v1.52H4.57ZM3.04 0h25.91v1.52H3.04Zm0 4.57h1.53v22.86H3.04ZM1.52 28.95h1.52v1.53H1.52Zm0-27.43h1.52v1.53H1.52ZM0 3.05h1.52v25.9H0Z" stroke="currentColor"></path></svg>
          <span class="text-sm font-semibold hover:underline hover:underline-offset-4">
            Cyril James De Guzman
          </span>
        </a>
      </address>
    </article>
    <ContactForm client:visible />
  </section>
</section>
