---
import { Image } from "astro:assets";
import aniquinch from "@/assets/projects/aniquinch-1.webp";
import huefit from "@/assets/projects/huefit-1.webp";
import onlyfunds from "@/assets/projects/onlyfunds-1.webp";
import pasabuy from "@/assets/projects/pasabuy-1.webp";
import promptwise from "@/assets/projects/promptwise-1.webp";
import smilecare from "@/assets/projects/smilecare-1.webp";
import superproxy from "@/assets/projects/superproxy-1.webp";
import thryve from "@/assets/projects/thryve-1.webp";
import SectionTitle from "@/components/section-title.astro";
import Badge from "@/components/ui/badge.astro";
import Button from "@/components/ui/button.astro";

type ProjectType = "Company" | "University" | "Personal";

interface Project {
  title: string;
  type: ProjectType;
  description: string;
  technologies: string[];
  draft?: boolean;
  images?: ImageMetadata[];
  websiteLink?: string;
  githubLink?: string;
}

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

const projects: Project[] = [
  {
    title: "PromptWise",
    type: "Company",
    description:
      "An AI Creative Studio with guided workflows and all-in-one tools for generating images, videos, and audio that comes in classic, conversational, and node-based interfaces. It also includes specialized tools, centralized asset and prompt management.",
    technologies: [
      "Next.js",
      "Prisma",
      "Supabase",
      "PostgreSQL",
      "Trigger.dev",
      "Cloudflare",
      "AI Generation",
    ],
    images: [promptwise],
    websiteLink: "https://promptwise.com/",
  },
  {
    title: "Superproxy",
    type: "Company",
    description:
      "A modern Customer Relationship Management web application featuring a conversational AI Sales Agent that calls and engages with clients on users’ behalf, alongside quotations, invoices, call recordings, email management, currency conversion, and analytics.",
    technologies: [
      "Next.js",
      "Supabase",
      "Prisma",
      "PostgreSQL",
      "ElevenLabs",
      "OpenAI",
    ],
    images: [superproxy],
    websiteLink: "https://www.superproxy.ai/",
  },
  {
    title: "Thryve",
    type: "Company",
    description:
      "A Dating site with gender-based profile discovery, profile management, liking and matching, an affiliate program, real-time messaging with voice and video calling.",
    technologies: ["Next.js", "Supabase", "Prisma", "PostgreSQL"],
    images: [thryve],
  },
  {
    title: "HueFit",
    type: "University",
    description:
      "A modern E-commerce mobile application featuring AI-powered and AR virtual fitting, skin tone-based outfit color matching, and a web-based system for inventory and order management.",
    technologies: [
      "Next.js",
      "Supabase",
      "Prisma",
      "React Native Expo",
      "FastAPI",
    ],
    images: [huefit],
    githubLink: "https://github.com/quinchy/Hue-Fit",
  },
  {
    title: "PasaBuy",
    type: "University",
    description:
      "An Android Application with location based pasabuy request posts, community platform, and ordering.",
    technologies: ["Android Studio", "Java", "Firebase"],
    images: [pasabuy],
    githubLink: "https://github.com/quinchy/Pasabuy",
  },
  {
    title: "SmileCare",
    type: "University",
    description:
      "A Website for a local dental clinic with an appointment system dashboard.",
    technologies: ["Laravel", "MySQL", "Heroku"],
    images: [smilecare],
    githubLink:
      "https://github.com/quinchy/Donna-Mae-Jorge-Hollman-Dental-Clinic-Scheduling-System",
  },
  {
    title: "OnlyFunds",
    type: "University",
    description:
      "A Basic mock-up of a Desktop Banking Application for OOP course.",
    technologies: ["C#", "WinForms", "MySQL"],
    images: [onlyfunds],
    githubLink: "https://github.com/quinchy/BankingSystem",
  },
  {
    title: "AniQuinch",
    type: "University",
    description:
      "A Basic Website built using HTML and CSS only mimicking an e-commerce website.",
    technologies: ["HTML", "CSS"],
    images: [aniquinch],
    websiteLink: "https://quinchx.github.io/AniQuinch/",
    githubLink: "https://github.com/QuinchX/AniQuinch",
  },
];

const showDrafts = import.meta.env.DEV;
const publishedProjects = projects.filter(
  (project) => showDrafts || !project.draft,
);
const visibleProjects = publishedProjects.slice(0, limit);
// ponytail: eager-load the above-the-fold thumbnails only on the dedicated
// /projects page (no limit); on the home page this section sits below the fold.
const eagerImages = limit ? 0 : 3;
---

<section class="flex flex-col spacing-md">
  <SectionTitle text="Projects" />

  <div class="flex flex-col spacing-lg">
    {
      visibleProjects.map((project, index) => (
        <div class="flex flex-col spacing-lg outline-1 outline-dashed outline-transparent outline-offset-xs animation-normal hover:outline-border lg:flex-row">
          <div class="flex min-w-0 flex-1 flex-col spacing-xs">
            <div class="flex items-center justify-between">
              <h2 class="flex items-center spacing-xs font-semibold text-primary">
                {project.title}
                {project.websiteLink && (
                  <a
                    href={project.websiteLink}
                    aria-label={`${project.title} Link`}
                    title={`${project.title} Link`}
                    class="text-foreground/75 animation-normal hover:scale-105 hover:text-foreground"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-4"><path fill="currentColor" d="M22 9V7h-1V5h-1V4h-1V3h-2V2h-2V1H9v1H7v1H5v1H4v1H3v2H2v2H1v7h1v1h1v2h1v1h1v1h2v1h2v1h6v-1h2v-1h2v-1h1v-1h1v-2h1v-2h1V9zm-1 1v4h-3v-4zm-5-6h1v1h2v2h1v1h-3V5h-1zm-2 14v2h-1v1h-2v-1h-1v-2H9v-2h6v2zm2-8v4H8v-4zM9 6h1V4h1V3h2v1h1v2h1v2H9zM4 7h1V5h2V4h1v1H7v3H4zm-1 7v-4h3v4zm2 5v-2H4v-1h3v3h1v1H7v-1zm14-2v2h-2v1h-1v-1h1v-3h3v1z"></path></svg>
                  </a>
                )}
                {project.githubLink && (
                  <a
                    href={project.githubLink}
                    aria-label={`${project.title} Github Link`}
                    title={`${project.title} Github Link`}
                    class="text-foreground/75 animation-normal hover:scale-105 hover:text-foreground"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-4"><path fill="currentColor" d="M5 2h4v2H7v2H5zm0 10H3V6h2zm2 2H5v-2h2zm2 2v-2H7v2H3v-2H1v2h2v2h4v4h2v-4h2v-2zm0 0v2H7v-2zm6-12v2H9V4zm4 2h-2V4h-2V2h4zm0 6V6h2v6zm-2 2v-2h2v2zm-2 2v-2h2v2zm0 2h-2v-2h2zm0 0h2v4h-2z" stroke="currentColor"></path></svg>
                  </a>
                )}
              </h2>
              <div
                class="flex items-center spacing-xs bg-muted padding-xs text-sm select-none"
                title={project.type}
              >
                {project.type === "Company" && (
                  <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" class="size-4 text-foreground/60"><path fill="currentColor" d="M2 2h14v4h6v16H2zm18 6h-4v2h2v2h-2v2h2v2h-2v2h2v2h2zm-6-4H4v16h2v-2h6v2h2zM6 6h2v2H6zm6 0h-2v2h2zm-6 4h2v2H6zm6 0h-2v2h2zm-6 4h2v2H6zm6 0h-2v2h2z"></path></svg>
                )}
                {project.type === "University" && (
                  <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="32" height="32" viewBox="0 0 32 32" class="size-4 text-foreground/60"><path fill="currentColor" d="M30.47 7.61h-1.52v3.05H25.9v1.53h-3.05v1.52h3.05v4.57h-1.52v1.53h1.52v3.04h1.52V12.19h1.53V25.9h-1.53V32H32v-6.1h-1.53zM25.9 6.09h3.05v1.52H25.9Z" stroke="currentColor"></path><path fill="currentColor" d="M24.38 22.85h1.52v1.53h-1.52ZM19.8 9.14h6.1v1.52h-6.1Zm3.05-4.57h3.05v1.52h-3.05Zm-1.52 19.81h3.05v1.52h-3.05Zm0-4.57h3.05v1.52h-3.05Zm-1.53-6.1h3.05v1.52H19.8Zm0-10.67h3.05v1.53H19.8ZM9.14 25.9h12.19v1.52H9.14Zm0-4.57h12.19v1.52H9.14Zm7.62-6.1h3.04v1.53h-3.04Zm-3.05-7.62h6.09v1.53h-6.09Zm3.05-6.09h3.04v1.52h-3.04ZM13.71 0h3.05v1.52h-3.05Zm0 16.76h3.05v1.52h-3.05ZM10.66 1.52h3.05v1.52h-3.05Zm0 13.71h3.05v1.53h-3.05ZM7.61 3.04h3.05v1.53H7.61ZM6.09 24.38h3.05v1.52H6.09Zm0-4.57h3.05v1.52H6.09Zm1.52-6.1h3.05v1.52H7.61ZM4.57 4.57h3.04v1.52H4.57Zm0 18.28h1.52v1.53H4.57Zm1.52-3.04v-1.53H4.57v-4.57h3.04v-1.52H4.57v-1.53H1.52v1.53h1.52v10.66h1.53v-3.04zM1.52 6.09h3.05v1.52H1.52ZM0 7.61h1.52v3.05H0Z" stroke="currentColor"></path></svg>
                )}
                {project.type === "Personal" && (
                  <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="32" height="32" viewBox="0 0 32 32" class="size-4 text-foreground/60"><path fill="currentColor" d="M30.47 26.665H1.52v-3.05H0v4.57h1.52v1.53h28.95v-1.53H32v-4.57h-1.53z" stroke="currentColor"></path><path fill="currentColor" d="M28.95 20.565h1.52v3.05h-1.52Zm-10.67-9.14h1.53v1.52h-1.53Zm-4.57 12.19h4.57v1.52h-4.57Zm1.53-12.19h1.52v1.52h-1.52Zm-3.05 0h1.52v1.52h-1.52Zm-7.62-9.14h22.86v1.52H4.57Z" stroke="currentColor"></path><path fill="currentColor" d="M28.95 20.565V3.805h-1.52v15.24H4.57V3.805H3.05v16.76zm-27.43 0h1.53v3.05H1.52Z" stroke="currentColor"></path></svg>
                )}
                <span>{project.type}</span>
              </div>
            </div>
            <p>{project.description}</p>
            <div class="flex flex-wrap spacing-xs">
              {project.technologies.map((tech) => (
                <Badge name={tech} />
              ))}
            </div>
          </div>
          <div class="lg:w-2/5 lg:shrink-0">
            {project.images?.[0] && (
              <Image
                widths={[360, 540, 760]}
                sizes="(min-width: 1024px) 360px, 100vw"
                src={project.images[0]}
                draggable="false"
                loading={index < eagerImages ? "eager" : "lazy"}
                class="aspect-project w-full border border-border object-cover select-none"
                alt={`${project.title} thumbnail`}
              />
            )}
          </div>
        </div>
      ))
    }
  </div>

  {
    limit && limit < publishedProjects.length && (
      <div class="flex justify-center">
        <Button
          href="/projects"
          variant="dashed"
          class="w-full animation-normal"
        >
          View All Projects
        </Button>
      </div>
    )
  }
</section>
