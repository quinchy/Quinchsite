<div
  data-toast-container
  class="fixed right-md bottom-md z-50 flex flex-col spacing-xs"
  aria-live="polite"
  aria-atomic="true"
></div>

<script>
  type ToastType = "success" | "warning" | "error" | "info";

  const toastWindow = window as Window & {
    quinchToast?: (message: string, type?: ToastType) => void;
  };

  const TOAST_DURATION = 3000;
  const TOAST_STYLES: Record<ToastType, string> = {
    success: "text-primary border-primary/50",
    warning: "text-primary border-primary/50",
    info: "text-primary border-primary/50",
    error: "text-rose-500/80 border-rose-500/80",
  };

  const createCloseIcon = () => {
    const icon = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    icon.setAttribute("aria-hidden", "true");
    icon.setAttribute("width", "24");
    icon.setAttribute("height", "24");
    icon.setAttribute("viewBox", "0 0 24 24");
    icon.classList.add("size-4");

    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    path.setAttribute("fill", "currentColor");
    path.setAttribute(
      "d",
      "M5 5h2v2H5zm4 4H7V7h2zm2 2H9V9h2zm2 0h-2v2H9v2H7v2H5v2h2v-2h2v-2h2v-2h2v2h2v2h2v2h2v-2h-2v-2h-2v-2h-2zm2-2v2h-2V9zm2-2v2h-2V7zm0 0V5h2v2z",
    );
    icon.append(path);

    return icon;
  };

  const removeToast = (toast: HTMLElement) => {
    toast.remove();
  };

  toastWindow.quinchToast = (message: string, type: ToastType = "info") => {
    const container = document.querySelector<HTMLElement>(
      "[data-toast-container]",
    );
    if (!container) return;

    const toast = document.createElement("div");
    toast.className = [
      "flex items-center justify-between spacing-sm border border-dashed bg-background padding-md text-sm font-medium toast-enter",
      TOAST_STYLES[type] ?? TOAST_STYLES.info,
    ].join(" ");

    const messageElement = document.createElement("span");
    messageElement.textContent = message;

    const close = document.createElement("button");
    close.type = "button";
    close.className = "animation-fast hover:opacity-70";
    close.setAttribute("aria-label", "Close toast");
    close.append(createCloseIcon());
    close.addEventListener("click", () => removeToast(toast));

    toast.append(messageElement, close);
    container.append(toast);

    window.setTimeout(() => removeToast(toast), TOAST_DURATION);
  };
</script>
