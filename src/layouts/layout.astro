---
import NavBar from "@/components/navbar.astro";
import Toast from "@/components/ui/toast";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cyril James - Full-Stack Engineer",
  description = "Full-Stack Engineer focused on systems design and scalable solutions across the full stack, with a goal of delivering highly performant, and reliable applications.",
} = Astro.props;

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") ?? "https://www.quinchy.dev";
const canonical = new URL(Astro.url.pathname, `${siteUrl}/`).toString();
const ogImage = `${siteUrl}/portfolio-thumbnail.png`;
const siteName = "Cyril James - Full-Stack Engineer";

// Structured data so AI/search engines have an unambiguous, accurate source of
// truth about who this site is about. Sourced from the page content below.
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Cyril James De Guzman",
      alternateName: "Quinchy",
      url: siteUrl,
      image: `${siteUrl}/profile-picture.webp`,
      jobTitle: "Full-Stack Engineer",
      description:
        "Full-stack engineer who builds scalable, reliable products across the stack and specializes in frontend engineering — intuitive, high-performance experiences with clean component architecture.",
      email: "deguzmancyriljames.dev@gmail.com",
      telephone: "+63-969-602-8487",
      address: { "@type": "PostalAddress", addressCountry: "PH" },
      sameAs: [
        "https://github.com/quinchy",
        "https://www.linkedin.com/in/quinchy",
      ],
      knowsAbout: [
        "Full-Stack Development",
        "Frontend Engineering",
        "TypeScript",
        "JavaScript",
        "React",
        "Next.js",
        "Astro",
        "Node.js",
        "Python",
        "Tailwind CSS",
        "PostgreSQL",
        "Prisma",
        "REST APIs",
        "tRPC",
        "AI Integration",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: siteName,
      description,
      inLanguage: "en",
      publisher: { "@id": `${siteUrl}/#person` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="preload"
      href="/fonts/GeistPixel-Square.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cyril James De Guzman" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content="Cyril James De Guzman" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteName} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <script is:inline>
      (function () {
        function apply() {
          try {
            const root = document.documentElement;
            const savedMode = localStorage.getItem("theme") || "system";
            const savedColor =
              localStorage.getItem("color-theme") || "default";

            const dark =
              savedMode === "dark" ||
              (savedMode === "system" &&
                window.matchMedia("(prefers-color-scheme: dark)").matches);

            root.classList.toggle("dark", dark);
            root.classList.remove("teal", "azure", "crimson", "aurora");
            if (["teal", "azure", "crimson", "aurora"].includes(savedColor)) {
              root.classList.add(savedColor);
            }
          } catch (e) {}
        }

        apply();

        // Disable transitions until the page is painted and restored, so the
        // hover-styled elements don't all animate once on load (removed by the
        // restore script at the end of <body>).
        document.documentElement.classList.add("preload");

        // Take over scroll restoration. The browser restores deep scroll
        // positions *after* first paint, flashing the top of the page. We
        // instead hide the page now and restore + reveal in one go (see the
        // script at the end of <body>) so the top never paints.
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";
        try {
          if (sessionStorage.getItem("scroll:" + location.pathname) !== null) {
            document.documentElement.classList.add("scroll-restoring");
          }
        } catch (e) {}
        // Failsafe: never leave the page hidden or transitions disabled.
        addEventListener("load", function () {
          document.documentElement.classList.remove("scroll-restoring");
          document.documentElement.classList.remove("preload");
        });
      })();
    </script>
  </head>
  <body>
    <NavBar />
    <main
      class="flex min-h-dvh justify-center overflow-x-hidden border-x border-b border-border"
    >
      <slot />
    </main>
    <Toast client:only="react" />
    <script is:inline>
      (function () {
        var key = "scroll:" + location.pathname;
        var saved = null;
        try {
          saved = sessionStorage.getItem(key);
        } catch (e) {}

        function startSaving() {
          var raf = 0;
          function save() {
            raf = 0;
            try {
              sessionStorage.setItem(key, String(window.scrollY));
            } catch (e) {}
          }
          addEventListener(
            "scroll",
            function () {
              if (!raf) raf = requestAnimationFrame(save);
            },
            { passive: true },
          );
          addEventListener("pagehide", save);
        }

        function restore() {
          // Reserved image boxes + fonts.ready mean the page is now at its final
          // height, so scrollTo lands exactly (no clamp drift). Save only after,
          // so the programmatic scroll never overwrites the saved position.
          if (saved !== null) window.scrollTo(0, parseInt(saved, 10));
          document.documentElement.classList.remove("scroll-restoring");
          // Re-enable transitions once the restored frame has painted.
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.documentElement.classList.remove("preload");
            });
          });
          startSaving();
        }

        if (saved !== null && document.fonts && document.fonts.ready) {
          var done = false;
          var finish = function () {
            if (done) return;
            done = true;
            restore();
          };
          document.fonts.ready.then(finish);
          setTimeout(finish, 1200); // failsafe if fonts.ready stalls
        } else {
          restore();
        }
      })();
    </script>
  </body>
</html>
